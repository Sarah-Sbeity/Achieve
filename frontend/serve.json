{
  "rewrites": [
    { "source": "/dashboard/**", "destination": "/index.html" },
    { "source": "/survey", "destination": "/index.html" },
    { "source": "/survey/*", "destination": "/index.html" },
    { "source": "/users", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" },
    { "source": "/invite", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" }
  ],
  "headers": [
    { "source": "**/*.js", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "**/*.css", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
    { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] }
  ]
}
